{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/chat",
      "destination": "https://sharktide-chat.hf.space",
      "permanent": false
    },
    {
      "source": "/chat/",
      "destination": "https://sharktide-chat.hf.space",
      "permanent": false
    },
    {
      "source": "/chat/:path*",
      "destination": "https://sharktide-chat.hf.space/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/ip-api/(.*)",
      "destination": "https://sharktide-lightning.hf.space/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://sharktide-lightning.hf.space/gen/$1"
    },
    {
      "source": "/MISC/(.*)",
      "destination": "https://raw.githubusercontent.com/sharktide/inferenceport-ai/refs/heads/main/MISC/$1"
    }
  ]
}
