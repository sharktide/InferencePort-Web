{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/chat",
      "destination": "https://hf.space",
      "permanent": false
    },
    {
      "source": "/chat/",
      "destination": "https://hf.space",
      "permanent": false
    },
    {
      "source": "/chat/:path*",
      "destination": "https://hf.space/:path*",
      "permanent": false
    },
    {
      "source": "/console",
      "destination": "console/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/ip-api/(.*)",
      "destination": "https://hf.space"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://hf.space"
    },
    {
      "source": "/MISC/(.*)",
      "destination": "https://githubusercontent.com"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "console.inferenceport.ai"
        }
      ],
      "destination": "/console/index.html"
    },
    {
      "source": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "console.inferenceport.ai"
        }
      ],
      "destination": "/console/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "console.inferenceport.ai"
        }
      ],
      "destination": "/console/:path*"
    }
  ]
}
