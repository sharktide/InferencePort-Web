{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "installCommand": "echo 'Using root buildCommand instead'",
  "redirects": [
    {
      "source": "/chat",
      "destination": "https://sharktide-chat.hf.space",
      "permanent": false
    },
    {
      "source": "/chat/",
      "destination": "https://sharktide-chat.hf.space",
      "permanent": false
    },
    {
      "source": "/chat/:path*",
      "destination": "https://sharktide-chat.hf.space/:path*",
      "permanent": false
    },
    {
      "source": "/oauth/authorize",
      "destination": "https://dpixehhdbtzsbckfektd.supabase.co/auth/v1/oauth/authorize",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/ip-api/(.*)",
      "destination": "https://sharktide-lightning.hf.space/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://sharktide-lightning.hf.space/gen/$1"
    },
    {
      "source": "/MISC/(.*)",
      "destination": "https://raw.githubusercontent.com/sharktide/inferenceport-ai/refs/heads/main/MISC/$1"
    },
    {
      "source": "/authcallback",
      "destination": "authcallback.html"
    },
    {
      "source": "/console",
      "destination": "/console/"
    },
    {
      "source": "/console/:path*",
      "destination": "/console/:path*"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "console.inferenceport.ai"
        }
      ],
      "dest": "/console/$1"
    }
  ]
}
