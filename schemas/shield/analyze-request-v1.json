{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://inferenceport.ai/schemas/shield/analyze-request-v1.json",
  "title": "ShieldAnalyzeRequest",
  "type": "object",
  "properties": {
    "email": {
      "type": ["string", "null"],
      "format": "email",
      "description": "User email address"
    },
    "phone": {
      "type": ["string", "null"],
      "description": "E.164 formatted phone number"
    },
    "username": {
      "type": ["string", "null"],
      "description": "User-chosen username"
    },
    "ip": {
      "type": ["string", "null"],
      "description": "IPv4 or IPv6 address"
    },
    "device_fingerprint": {
      "type": ["string", "null"],
      "description": "Opaque device fingerprint string"
    },
    "geolocation": {
      "type": ["object", "null"],
      "description": "Optional geolocation data",
      "properties": {
        "country": { "type": "string" },
        "city": { "type": "string" }
      },
      "additionalProperties": true
    },
    "signup_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO8601 timestamp of signup"
    },
    "content": {
      "type": ["string", "null"],
      "description": "User-generated content for threat analysis"
    },
    "metadata": {
      "type": ["object", "null"],
      "description": "Arbitrary metadata for behavioral and identity analysis",
      "properties": {
        "account_id": { "type": "string" },
        "user_id": { "type": "string" },
        "external_user_id": { "type": "string" },
        "user_agent": { "type": "string" },
        "referrer": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
